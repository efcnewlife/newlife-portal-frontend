VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_TIMEOUT=90000
VITE_USE_MOCK_API=true

# development only: show email/password block on sign-in (pnpm dev + MODE=development)
VITE_SHOW_DEV_LOGIN=true
VITE_USE_MOCK_DEMO=true
VITE_SKIP_AUTH=false

VITE_APP_NAME=Newlife Portal
VITE_APP_TITLE=Newlife Portal
VITE_APP_VERSION=0.1.0

VITE_ENABLE_DEBUG=true
VITE_LOG_LEVEL=info

# Microsoft Entra ID (optional — enables "Sign in with Microsoft" on the Admin Portal sign-in page)
# Use the same SPA app registration client ID as AZURE_SPA_CLIENT_ID on the API.
# VITE_AZURE_CLIENT_ID=
# VITE_AZURE_TENANT_ID=
# VITE_AZURE_REDIRECT_URI=http://localhost:5173
