{
  "name": "newlife-portal-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "type-check": "tsc -b --noEmit",
    "build": "tsc -b && vite build",
    "build:stg": "tsc -b && vite build --mode staging",
    "build:prod": "tsc -b && vite build --mode production",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:stg": "vite preview --mode staging",
    "preview:prod": "vite preview --mode production"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "flatpickr": "^4.6.13",
    "i18next": "^25.9.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "@efcnewlife/newlife-ui": "^0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.8",
    "react-icons": "^5.5.0",
    "react-router": "^7.1.5",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0",
    "vite-plugin-svgr": "^4.3.0"
  },
  "pnpm": {
    "overrides": {
      "react-helmet-async>react": "^16.8.0 || ^17 || ^18 || ^19"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
